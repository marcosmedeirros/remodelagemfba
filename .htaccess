# Habilitar log de erros
php_flag display_errors On
php_flag log_errors On

# Charset padrão
AddDefaultCharset UTF-8

# Favicon & ícones antigos -> novos caminhos
<IfModule mod_rewrite.c>
    RewriteEngine On
    # Favicon padrão (PNG funciona em navegadores modernos)
    RewriteRule ^favicon\.ico$ /img/icons/icon-96.png [L]
    
    # Compatibilidade com caminhos antigos
    RewriteRule ^img/fba-logo\.png$ /img/icons/icon-180.png [L]
    RewriteRule ^img/icon-192\.png$ /img/icons/icon-192.png [L]
    RewriteRule ^img/icon-96\.png$ /img/icons/icon-96.png [L]
    RewriteRule ^img/icon-48\.png$ /img/icons/icon-48.png [L]
</IfModule>

# Compressão
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Cache de recursos estáticos
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/x-icon "access plus 1 year"
</IfModule>

# Rewrite rules
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Alias amigavel: /novo/... -> /novos/...
    RewriteRule ^novo/(.*)$ /novos/$1 [L,NC]
    
    # Redirecionar para HTTPS (descomente se tiver SSL)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
    
    # Bloquear acesso a arquivos sensíveis
    RewriteRule ^\.git - [F,L]
    RewriteRule ^backend/config\.php$ - [F,L]
    RewriteRule ^sql/ - [F,L]

    # Compatibilidade: links antigos de reset com /games/auth/...
    RewriteRule ^games/auth/resetar\.php$ /auth/resetar.php [L,R=301]
</IfModule>

# Proteção de arquivos
<FilesMatch "\.(htaccess|htpasswd|ini|log|sh|sql)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Permitir acesso específico ao migrate.php temporariamente
<Files "migrate.php">
    Order Allow,Deny
    Allow from all
</Files>
